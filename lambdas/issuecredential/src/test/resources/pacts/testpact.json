{
  "consumer": {
    "name": "IpvCoreBack"
  },
  "interactions": [
    {
      "description": "Valid POST request",
      "providerStates": [
        {
          "name": "dummyApiKey is a valid api key"
        },
        {
          "name": "dummyAccessToken is a valid access token"
        },
        {
          "name": "test-subject is a valid subject"
        },
        {
          "name": "dummyPassportComponentId is a valid issuer"
        },
        {
          "name": "VC givenName is Mary"
        },
        {
          "name": "VC familyName is Watson"
        },
        {
          "name": "VC birthDate is 1932-02-25"
        },
        {
          "name": "VC passport documentNumber is 824159121"
        },
        {
          "name": "VC passport expiryDate is 2030-01-01"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer dummyAccessToken",
          "x-api-key": "dummyApiKey"
        },
        "method": "POST",
        "path": "/issue/credential"
      },
      "response": {
        "headers": {
          "Content-Type": "application/jwt; charset=UTF-8"
        },
        "body": "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzI1NiJ9..lDEi47XWnjyZ20fU-vb02BV1MSan68AqLUEQxCZGM_r8i4bG06uzdpXOJZeg-Kdhsf-NtWbqb-xM0P36YGwIeg",
        "matchingRules": {
          "body": {
            "$": {
              "matchers": [
                {
                  "match": "regex",
                  "regex": "^eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzI1NiJ9.*",
                  "value": "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzI1NiJ9"
                }
              ],
              "combine": "AND"
            }
          }
        },
        "status": 200
      }
    }
  ],
  "metadata": {
    "pact-jvm": {
      "version": "4.6.3"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "PassportCriProvider"
  }
}